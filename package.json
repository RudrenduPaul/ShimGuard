{
  "name": "shimguard-cli",
  "version": "0.1.4",
  "description": "Verify that a GitHub issue closed as \"fixed\" actually has a merged fix. Catches security issues marked fixed whose PR was never merged.",
  "keywords": [
    "security",
    "cli",
    "github",
    "issue-tracker",
    "verification",
    "supply-chain",
    "vulnerability-scanner",
    "agent-native"
  ],
  "homepage": "https://github.com/RudrenduPaul/ShimGuard#readme",
  "bugs": {
    "url": "https://github.com/RudrenduPaul/ShimGuard/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RudrenduPaul/ShimGuard.git"
  },
  "license": "MIT",
  "author": "Rudrendu Paul",
  "type": "module",
  "bin": {
    "shimguard": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src test --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^8.57.0",
    "typescript": "^5.5.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "commander": "^12.1.0"
  }
}
